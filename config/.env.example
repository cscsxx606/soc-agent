# SOC Agent 配置文件模板
# 复制本文件为 config/.env 并填入真实值
# cp config/.env.example config/.env

# ============================================================
# LLM 模型配置（必需）
# ============================================================
# 推荐使用 SiliconFlow 或 OpenAI/兼容 API
API_KEY=sk-your-api-key-here
BASE_URL=https://api.siliconflow.cn/v1
MODEL=deepseek-ai/DeepSeek-V3

# ============================================================
# 安全密钥（强烈建议生产环境设置）
# ============================================================
# Flask session + JWT 签名用同一密钥（多 worker 必须一致）
# 生成: openssl rand -hex 32
SOC_ADMIN_FLASK_SECRET=your-flask-secret-generate-with-openssl-rand-hex-32
SOC_ADMIN_SECRET=your-jwt-secret-generate-with-openssl-rand-hex-32

# ============================================================
# EDR 探针配置（可选）
# ============================================================
# osqueryd 探针注册密钥（生产环境必填，未填则启动时自动生成并打印）
# 生成: openssl rand -hex 32
EDR_ENROLL_SECRET=
# EDR 服务允许的 CORS 来源（逗号分隔）
EDR_ALLOWED_ORIGINS=http://localhost:8889,http://127.0.0.1:8889

# ============================================================
# 功能开关
# ============================================================
# 自动处置（高风险！默认关闭需人工确认）
ENABLE_AUTO_RESPONSE=false
# 时区
TZ=Asia/Shanghai

# ============================================================
# Web 管理后台（可选）
# ============================================================
# Flask secret 与 SOC_ADMIN_FLASK_SECRET 共享
# 默认账号: admin / admin123（首次登录后请修改）
